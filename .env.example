# TSN Bugfix Driver Workflow (minimal config)
# 复制为 `.env.local` 使用。`pnpm bugfix:workflow` 与 `pnpm openapi:pull:generate` 会自动加载 `.env.local`（dotenv）。

# Jira / Atlassian (required)
ATLASSIAN_SITE_URL=https://your-company.atlassian.net
ATLASSIAN_EMAIL=you@company.com
ATLASSIAN_API_TOKEN=your_atlassian_api_token

# Jira options (optional)
JIRA_PROJECT_KEY=TSN
# JIRA_DEV_DONE_NAME=Closed

# Slack (required)
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_CHANNEL_ID=CXXXXXXXX

# CI wait (optional)
BUGFIX_GHA_TIMEOUT_MINUTES=30

# Advanced overrides (optional)
# BUGFIX_TAG_PREFIX=tms-fe-v
# BUGFIX_GHA_WORKFLOW_FILE=tags.yml
# BUGFIX_CI_VERBOSE=0
# GITHUB_REPO_REMOTE_URL=git@github.com:inteluck/tms_frontend.git


# OpenAPI：用于 `pnpm openapi:pull:generate`（可选；不设则跳过拉取；脚本会自动读 `.env.local`）
# SpringDoc 3.x 常见路径为 `/v3/api-docs`；以你们网关/服务实际为准。
OPENAPI_TMS_URL=https://test.gaia.inteluck.com/api/v3/api-docs
OPENAPI_UAM_URL=https://test.hades.inteluck.com/api/v3/api-docs
